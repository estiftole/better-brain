---
layout: base.njk
title: Welcome to the Publication
---

<section class="hero">
  <h1>Systems & Infrastructure Engineering</h1>
  <p>A multi-author technical publication covering databases, compilers, and web performance.</p>
  <a href="/contribute/" class="btn">Become a Writer</a>
</section>

<section class="latest-posts">
  <h2>Latest Writeups</h2>

  {# Loop through posts in reverse chronological order #}
  <div class="post-grid">
    {% for post in collections.posts | reverse %}
      {% if loop.index <= 3 %} {# Limit to top 3 #}
        <article class="post-card">
          <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
          <time>{{ post.date | readableDate }}</time>
          <!--<p>Written by <strong>{{ authors[post.data.author].name }}</strong></p>-->
          <!--<p>Written by <strong>{{ post.data.author }}</strong></p>-->
        </article>
      {% endif %}
    {% endfor %}
  </div>
</section>
