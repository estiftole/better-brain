---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <time>{{ page.date | readableDate }}</time>

    {% if author %}
      <span class="byline">By {{ author }}</span>
    {% endif %}
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>
</article>
