---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <p class="post-by">
    <time>{{ page.date | readableDate }}</time>

    {% if author %}
        <a> • {{ author }}</a>
    {% endif %}
    </p>
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>
</article>
